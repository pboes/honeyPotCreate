# Honey Pot – Environment Variables
# Copy this file to .env and fill in the values.
#   cp .env.example .env

# ── Encryption ────────────────────────────────────────────────────────────────
# 64 hex characters = 32 bytes = AES-256 key.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# WARNING: if you lose this key you cannot decrypt existing registrations.
ENCRYPTION_KEY=

# ── Server ────────────────────────────────────────────────────────────────────
# Port the Express registration backend listens on (default: 3001).
PORT=3001