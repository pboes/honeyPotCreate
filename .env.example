# Honey Pot Create – Environment Variables
# Copy this file to .env and fill in the values.
#   cp .env.example .env

# ── Encryption ────────────────────────────────────────────────────────────────
# 64 hex characters = 32 bytes = AES-256 key.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# WARNING: if you lose this key you cannot decrypt existing registrations.
# This same key must be set in the Redeem app's .env too.
ENCRYPTION_KEY=

# ── Upstash Redis ─────────────────────────────────────────────────────────────
# Create a free database at https://console.upstash.com
# Then copy the REST API URL and token from the database dashboard.
# If these are not set, the app falls back to local file storage (data/registrations.json).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Server ────────────────────────────────────────────────────────────────────
# Port the Express registration backend listens on (default: 3001).
PORT=3001